digraph ruby_modules {
  rankdir=LR;
  graph [compound=true, overlap=false, splines=true];
  node [shape=box, style="rounded,filled", fillcolor="#f8fafc", color="#94a3b8", fontname="Helvetica"];
  edge [color="#64748b", arrowsize=0.7, fontname="Helvetica"];
  subgraph "cluster_packages_billing" {
    label="packages/billing";
    style="rounded,filled";
    color="#cbd5e1";
    fillcolor="#f1f5f9";
    "Invoice" [label="Invoice"];
  }
  subgraph "cluster_packages_auth" {
    label="packages/auth";
    style="rounded,filled";
    color="#cbd5e1";
    fillcolor="#f1f5f9";
    "User" [label="User"];
  }
  "Application";

  "Invoice" -> "Application" [label="inherits", color="#0f172a", penwidth=2.0];
  "User" -> "Application" [label="inherits", color="#0f172a", penwidth=2.0];
}
